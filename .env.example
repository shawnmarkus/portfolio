# Copy this file to .env and fill in your values

# Optional: URL to your portfolio.json hosted on GitHub (raw URL)
# When set, the site fetches live data from this URL at runtime.
# Leave empty to use the bundled src/data/portfolio.json instead.
#
# Example:
# VITE_DATA_URL=https://raw.githubusercontent.com/shivam-sharma/portfolio/main/portfolio.json
VITE_DATA_URL=
